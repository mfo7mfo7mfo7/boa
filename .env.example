BOA_IMAGE=boa:local
BOA_PORT=8000
BOA_JOURNEY_FOLD_DAYS=15
# SMTP configuration for the Engine Room mail route.
# Set BOA_SMTP_ENABLED=true to enable outbound email.
BOA_SMTP_ENABLED=false
BOA_SMTP_HOST=
BOA_SMTP_PORT=587
BOA_SMTP_USERNAME=
BOA_SMTP_PASSWORD=
BOA_SMTP_FROM=
BOA_SMTP_FROM_NAME=Boa
BOA_SMTP_STARTTLS=true
BOA_SMTP_SSL=false
BOA_SMTP_TIMEOUT=15
# Optional default recipient for test emails from the Engine Room.
BOA_SMTP_TEST_TO=

# Email Mark Workflow.
# Public URL used to build secret acknowledgement links in outbound emails.
# Local development example: http://127.0.0.1:8000
# Reverse-proxy example: http://gitlab.qa:4001
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Hours until an acknowledgement link expires. Default: 168 (7 days).
BOA_ACK_TOKEN_TTL_HOURS=168
# Comma-separated days before a milestone to send reminder emails. Default: 7,3,1
BOA_REMINDER_DAYS_BEFORE=7,3,1

# Common SMTP provider examples (uncomment and fill in for your provider):
#
# Gmail / Google Workspace:
# BOA_SMTP_HOST=smtp.gmail.com
# BOA_SMTP_PORT=587
# BOA_SMTP_STARTTLS=true
# BOA_SMTP_SSL=false
# BOA_SMTP_USERNAME=boa@example.com
# BOA_SMTP_PASSWORD=<app-password>
# BOA_SMTP_FROM=boa@example.com
#
# Microsoft 365:
# BOA_SMTP_HOST=smtp.office365.com
# BOA_SMTP_PORT=587
# BOA_SMTP_STARTTLS=true
# BOA_SMTP_SSL=false
# BOA_SMTP_USERNAME=boa@example.com
# BOA_SMTP_PASSWORD=<password>
# BOA_SMTP_FROM=boa@example.com
#
# SendGrid:
# BOA_SMTP_HOST=smtp.sendgrid.net
# BOA_SMTP_PORT=587
# BOA_SMTP_USERNAME=apikey
# BOA_SMTP_PASSWORD=<SENDGRID_API_KEY>
# BOA_SMTP_FROM=boa@example.com
#
# Amazon SES:
# BOA_SMTP_HOST=email-smtp.<region>.amazonaws.com
# BOA_SMTP_PORT=587
# BOA_SMTP_USERNAME=<SMTP_USERNAME>
# BOA_SMTP_PASSWORD=<SMTP_PASSWORD>
# BOA_SMTP_FROM=boa@example.com
